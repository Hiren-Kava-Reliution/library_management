<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <record id="library_book_list_view" model="ir.ui.view">
        <field name="name">library.book.list.view</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <list string="Library Book">
                <field name="name"/>
                <field name="author"/>
                <field name="available_qty"/>
            </list>
        </field>
    </record>

    <record id="library_book_form_view" model="ir.ui.view">
        <field name="name">library.book.form.view</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form string="Library Book">
                <sheet>
                    <group string="Book Information">
                        <field name="name"/>
                        <field name="author"/>
                        <field name="available_qty"/>
                        <field name="is_available"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="library_book_action" model="ir.actions.act_window">
        <field name="name">Library Book</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>