<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <record id="library_member_list_view" model="ir.ui.view">
        <field name="name">library.member.list.view</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <list string="Library Member Details">
                <field name="name"/>
                <field name="email"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="library_member_form_view" model="ir.ui.view">
        <field name="name">library.member.form.view</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <form string="Library Member">
                <sheet>
                    <group string="Member Information">
                        <field name="name"/>
                        <field name="email"/>
                        <field name="is_active"/>
                    </group>
                    <notebook>
                        <page string="Issued Books">
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="library_member_action" model="ir.actions.act_window">
        <field name="name">Library Member</field>
        <field name="res_model">library.member</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>